# ──────────────────────────────────────────────────────────────────────────
# ORACLE — environment configuration
# Copy this file to `.env` in the `backend/` folder and fill in real values.
# See /docs/GET_API_KEYS.md for step-by-step instructions on obtaining
# every key below.
# ──────────────────────────────────────────────────────────────────────────

# ── LLM: OpenRouter (free-tier models) ──────────────────────────────────
# Get a key at https://openrouter.ai/keys (see docs/GET_API_KEYS.md)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Comma-separated, tried in order with automatic failover if one is rate
# limited / errors / returns empty. Check https://openrouter.ai/models
# for the current list of ":free" suffixed slugs to change models.
OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen-2.5-72b-instruct:free,mistralai/mistral-7b-instruct:free
# Optional - only needed if we want OpenRouter to attribute usage to us
# on the leaderboards / for higher free-tier rate limits.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=ORACLE Research Assistant

# ── Web Search: Tavily ───────────────────────────────────────────────────
# Get a key at https://tavily.com (see docs/GET_API_KEYS.md)
TAVILY_API_KEY=tvly-REPLACE_ME

# ── Observability: LangSmith ─────────────────────────────────────────────
# Get a key at https://smith.langchain.com (see docs/GET_API_KEYS.md)
# Do LANGSMITH_TRACING=false to run with tracing fully disabled.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_REPLACE_ME
LANGSMITH_PROJECT=oracle-research-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Citation lookups: CrossRef ───────────────────────────────────────────
# CrossRef's API is free and keyless, but including a contact email puts
# us in their faster, more reliable "polite pool". Just use your own email.
CROSSREF_MAILTO=you@example.com

# ── Embeddings ────────────────────────────────────────────────────────────
# "huggingface" runs BAAI/bge-small-en-v1.5 locally (free), no key, no
# network calls at inference time (only the first run downloads weights).
# "openai" uses text-embedding-3-small via the OpenAI API if you'd rather
# pay for slightly higher quality embeddings.
EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector store: Chroma ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=oracle_documents

# ── LangGraph checkpointing ──────────────────────────────────────────────
# "sqlite" for local single-process dev. Switch to DATABASE_URL (Postgres)
# in production so human-in-the-loop interrupts survive server restarts.
CHECKPOINTER_BACKEND=sqlite
CHECKPOINTER_SQLITE_PATH=./data/checkpoints.sqlite

# ── Database: PostgreSQL (Supabase in production) ────────────────────────
DATABASE_URL=postgresql+asyncpg://oracle:oracle@localhost:5432/oracle

# ── Queue: Redis / Celery ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── API ──────────────────────────────────────────────────────────────────
# Comma-separated list of origins the frontend is allowed to call the API
# from (CORS). The Next.js dev server default is included already.
CORS_ALLOW_ORIGINS=http://localhost:3000

# ── App behaviour ──────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_SUBTASKS_PER_PLAN=6
AGENT_LLM_TIMEOUT_SECONDS=60
CODE_EXEC_TIMEOUT_SECONDS=15
CODE_EXEC_MAX_OUTPUT_CHARS=8000
